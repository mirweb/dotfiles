# Secret environment variables — NOT checked into the repo.
#
# Setup:
#   cp ~/.config/fish/conf.d/secrets.fish.example ~/.config/fish/conf.d/secrets.fish
#   # dann Werte eintragen und speichern — fish lädt die Datei automatisch beim nächsten Start
#   # oder sofort: source ~/.config/fish/conf.d/secrets.fish
#
# Die Datei secrets.fish ist in .gitignore eingetragen und wird nie committed.

# GitHub
set -gx GITHUB_TOKEN "your_github_token_here"

# AWS
# set -gx AWS_ACCESS_KEY_ID     "your_key_id_here"
# set -gx AWS_SECRET_ACCESS_KEY "your_secret_here"
# set -gx AWS_DEFAULT_REGION    "eu-central-1"

# OpenAI / Anthropic
# set -gx OPENAI_API_KEY    "sk-..."
# set -gx ANTHROPIC_API_KEY "sk-ant-..."

# Weitere Secrets hier ergänzen...

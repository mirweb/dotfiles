# shell completion for brew https://docs.brew.sh/Shell-Completion
if type brew &>/dev/null; then
  FPATH="$(brew --prefix)/share/zsh/site-functions:${FPATH}"
fi

# History behavior
HISTSIZE=50000
SAVEHIST=50000
HISTFILE=~/.zsh_history
setopt appendhistory
setopt sharehistory
setopt hist_ignore_all_dups
setopt hist_reduce_blanks

# Be conservative like previous config
unsetopt correct

# Completion
autoload -Uz compinit
compinit

# Use modern completion menu behavior
zmodload zsh/complist
setopt auto_menu
setopt complete_in_word
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'

# Enable docker completion option stacking (kept from old config)
zstyle ':completion:*:*:docker:*' option-stacking yes
zstyle ':completion:*:*:docker-*:*' option-stacking yes

# Prompt (oh-my-zsh independent), similar compact style:
# user@host:path (git-branch) %#
autoload -Uz colors vcs_info
colors
precmd() { vcs_info }
zstyle ':vcs_info:git:*' formats ' (%F{cyan}%b%f)'
setopt prompt_subst
PROMPT='%F{green}%n@%m%f:%F{blue}%~%f${vcs_info_msg_0_} %# '

# aliases (kept from old config)
alias vi='vim'
alias o='xdg-open'
alias ansible-playbook='ansible-playbook --vault-password-file ~/.ansible_vault_pw'
alias ..='cd ..'
alias ...='cd ../..'
alias ll='ls -lah'
alias la='ls -A'
alias l='ls -CF'
alias dk='docker'

# Useful keybindings
bindkey -e
bindkey '^[[1;5C' forward-word
bindkey '^[[1;5D' backward-word
